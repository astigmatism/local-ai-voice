    "@fastify/swagger-ui": "^5.2.3",
    "@local-ai-voice/shared": "workspace:*",
    "fastify": "^5.3.3",
    "pino": "^9.7.0",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "vitest": "^3.1.4"
