PUBLIC_HOST=0.0.0.0
PUBLIC_PORT=8000
NODE_ENV=production
LOG_LEVEL=info
PORTAL_ENABLED=true
PORTAL_DIST_DIR=/opt/local-ai-voice/app/apps/portal/dist
CORS_ORIGIN=http://local-ai-voice.local:8000

STT_WORKER_URL=http://127.0.0.1:8002
TTS_WORKER_URL=http://127.0.0.1:8001
WORKER_TIMEOUT_MS=120000
ALLOW_SYSTEMD_RESTART=false
STT_SYSTEMD_SERVICE=local-ai-voice-stt-worker.service
TTS_SYSTEMD_SERVICE=local-ai-voice-tts-chatterbox.service

BASE_DIR=/opt/local-ai-voice
CONFIG_DIR=/opt/local-ai-voice/config
MODEL_DIR=/opt/local-ai-voice/models
CACHE_DIR=/opt/local-ai-voice/cache
VOICE_DIR=/opt/local-ai-voice/voices
UPLOAD_DIR=/opt/local-ai-voice/uploads
OUTPUT_DIR=/opt/local-ai-voice/output
LOG_DIR=/opt/local-ai-voice/logs

GPU_ONLY=true
CUDA_VISIBLE_DEVICES=0
DEFAULT_STT_PROVIDER=fast-whisper
DEFAULT_STT_MODEL=large-v3-turbo
DEFAULT_STT_COMPUTE_TYPE=int8_float16
DEFAULT_STT_DEVICE=cuda
DEFAULT_TTS_PROVIDER=chatterbox
DEFAULT_TTS_MODEL=chatterbox-turbo
DEFAULT_TTS_LANGUAGE=en

MAX_UPLOAD_BYTES=104857600
GENERATED_RETENTION_HOURS=24
AUTH_ENABLED=false
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=
