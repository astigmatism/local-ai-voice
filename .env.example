# Public Node gateway. Keep 0.0.0.0 only on a trusted LAN, VPN, or reverse proxy.
PUBLIC_HOST=0.0.0.0
PUBLIC_PORT=8000
NODE_ENV=production
LOG_LEVEL=info

# Portal/static assets
PORTAL_ENABLED=true
PORTAL_DIST_DIR=/opt/local-ai-voice/app/apps/portal/dist
CORS_ORIGIN=http://localhost:8000

# Internal worker endpoints. Workers bind localhost only.
STT_WORKER_URL=http://127.0.0.1:8002
TTS_WORKER_URL=http://127.0.0.1:8001
WORKER_TIMEOUT_MS=120000

# Systemd hard-restart integration is disabled by default. Enable only after sudoers/polkit is configured.
ALLOW_SYSTEMD_RESTART=false
STT_SYSTEMD_SERVICE=local-ai-voice-stt-worker.service
TTS_SYSTEMD_SERVICE=local-ai-voice-tts-chatterbox.service

# Production data layout
BASE_DIR=/opt/local-ai-voice
CONFIG_DIR=/opt/local-ai-voice/config
MODEL_DIR=/opt/local-ai-voice/models
CACHE_DIR=/opt/local-ai-voice/cache
VOICE_DIR=/opt/local-ai-voice/voices
UPLOAD_DIR=/opt/local-ai-voice/uploads
OUTPUT_DIR=/opt/local-ai-voice/output
LOG_DIR=/opt/local-ai-voice/logs

# Defaults are GPU-first. Do not set GPU_ONLY=false unless intentionally testing degraded behavior.
GPU_ONLY=true
CUDA_VISIBLE_DEVICES=0

# STT defaults and loading behavior.
DEFAULT_STT_PROVIDER=fast-whisper
DEFAULT_STT_MODEL=large-v3-turbo
DEFAULT_STT_COMPUTE_TYPE=int8_float16
DEFAULT_STT_DEVICE=cuda

# When true, the STT worker will lazy-load the default model on the first transcription request.
STT_AUTO_LOAD_DEFAULT=true

# When true, the STT worker will load the default STT model during worker startup.
# Enable this on production appliances when STT should be warm after reboot or service restart.
STT_PRELOAD_DEFAULT=false

# TTS defaults and loading behavior.
DEFAULT_TTS_PROVIDER=chatterbox
DEFAULT_TTS_MODEL=chatterbox-turbo
DEFAULT_TTS_LANGUAGE=en

# When true, the TTS worker will lazy-load the default model on the first speech request.
TTS_AUTO_LOAD_DEFAULT=true

# When true, the TTS worker will load the default TTS model during worker startup.
# Enable this on production appliances when TTS should be warm after reboot or service restart.
# Keep false if VRAM is tight or if STT should have priority.
TTS_PRELOAD_DEFAULT=false

MAX_UPLOAD_BYTES=104857600
GENERATED_RETENTION_HOURS=24

# Local appliance auth placeholder. For production, prefer VPN/reverse proxy auth.
AUTH_ENABLED=false
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=